  if(!positions.length){
    html+=`<div class="empty-note">No positions yet — add one below.</div>`;
  } else {
    positions.forEach((p,idx)=>{
      const c=posCol(idx);
      const pctOfTotal=invested>0?Math.round((p.monthlyAmount||0)/invested*100):0;
      html+=`
      <div class="pos-row" id="posrow-${p.id}">
        <div style="display:flex;align-items:center;gap:9px">
          <div style="width:10px;height:10px;border-radius:50%;background:${c};flex-shrink:0"></div>
          <span class="pos-ticker" style="color:${c}" id="pticker-${p.id}">${p.ticker}</span>
          <span style="flex:1"></span>
          <span style="font-size:0.8rem;font-weight:500" id="pamt-${p.id}" class="editable">${fmt(p.monthlyAmount)}<span style="color:var(--muted);font-size:0.65rem">/mo</span></span>
          <button class="btn sec sm" onclick="deletePosition('${p.id}')">✕</button>
        </div>
        <div class="pos-meta" style="padding-left:19px;margin-top:3px">
          <span id="pbroker-${p.id}" class="editable" style="margin-right:8px">${p.broker||'—'}</span>
          <span style="background:var(--surface2);border:1px solid var(--border);padding:1px 5px;border-radius:2px;margin-right:8px" id="ptype-${p.id}" class="editable">${p.type||'—'}</span>
          ${p.notes?`<span id="pnotes-${p.id}" class="editable" style="font-style:italic">${p.notes}</span>`:`<span id="pnotes-${p.id}" class="editable" style="font-style:italic;opacity:.5">add notes</span>`}
        </div>
        <div style="padding-left:19px;margin-top:5px">
          <div style="height:3px;background:var(--surface2);border-radius:2px;max-width:180px;overflow:hidden">
            <div style="height:100%;width:${pctOfTotal}%;background:${c};border-radius:2px"></div>
          </div>
          <span style="font-size:0.62rem;color:var(--muted)">${pctOfTotal}% of portfolio</span>
        </div>
      </div>`;
    });
  }

  html+=`
      <div class="section-label">Add Position</div>
      <div class="add-row" style="flex-wrap:wrap">
        <input class="inp" id="new-ticker" placeholder="Ticker (VOO…)" style="max-width:100px;text-transform:uppercase" />
        <input class="inp" id="new-broker" placeholder="Broker" style="max-width:110px" />
        <input class="inp" id="new-type"   placeholder="Type (ETF…)" style="max-width:110px" />
        <input class="inp" type="number" id="new-inv-amt" placeholder="$/mo" min="0" step="1" style="max-width:90px" />
        <input class="inp" id="new-inv-notes" placeholder="Notes" />
        <button class="btn" onclick="addPosition()">+ Add</button>
      </div>
    </div>
  </div>`;

  // Allocation bar
  if(positions.length>1){
    html+=`
    <div class="summary-card" style="margin-top:10px">
      <div style="font-size:0.63rem;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px">Portfolio Allocation</div>
      <div class="alloc-bar">
        ${positions.map((p,i)=>{
          const w=invested>0?Math.round((p.monthlyAmount||0)/invested*100):0;
          return`<div style="width:${w}%;background:${posCol(i)};min-width:${w>0?'4px':'0'}" title="${p.ticker}: ${w}%"></div>`;
        }).join('')}
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:9px;margin-top:7px">
        ${positions.map((p,i)=>{
          const w=invested>0?Math.round((p.monthlyAmount||0)/invested*100):0;
          return`<span style="font-size:0.67rem;color:var(--muted);display:flex;align-items:center;gap:4px">
            <span style="width:8px;height:8px;border-radius:50%;background:${posCol(i)};display:inline-block"></span>
            ${p.ticker} ${w}%
          </span>`;
        }).join('')}
      </div>
    </div>`;
  }

  document.getElementById('panel-investing').innerHTML=html;

  // Inline edit: invest target %
  const targetDisp=document.getElementById('inv-target-disp');
  if(targetDisp){
    targetDisp.onclick=e=>{
      e.stopPropagation();
      const inp=document.createElement('input');
      inp.className='inline-inp inp';inp.type='number';inp.min='0';inp.max='100';inp.step='1';inp.value=cfg.investTarget;inp.style.width='55px';
      targetDisp.replaceWith(inp);inp.focus();inp.select();
      function commit(){const v=parseFloat(inp.value);if(!isNaN(v)&&v>=0&&v<=100){cfg.investTarget=v;svCfg();}renderInvesting();renderOverview();}
      inp.addEventListener('blur',commit);
      inp.addEventListener('keydown',e=>{if(e.key==='Enter')inp.blur();});
    };
  }

  // Inline edits for each position
  positions.forEach(p=>{
    function wireInline(elId, field, type='text', transform=(v)=>v){
      const el=document.getElementById(elId);
      if(!el)return;
      el.style.cursor='pointer';
      el.onclick=e=>{
        e.stopPropagation();
        const inp=document.createElement('input');
        inp.className='inline-inp inp';inp.type=type;inp.value=p[field]||'';inp.style.width='110px';
        if(type==='number'){inp.min='0';inp.step='1';}
        el.replaceWith(inp);inp.focus();inp.select();
        function commit(){
          const raw=inp.value.trim();
          const v=type==='number'?parseFloat(raw):raw;
          if(type==='number'){if(!isNaN(v)&&v>=0)p[field]=v;}
          else{if(raw)p[field]=transform(raw);}
          svPositions();renderInvesting();renderOverview();
        }
        inp.addEventListener('blur',commit);
        inp.addEventListener('keydown',e=>{if(e.key==='Enter')inp.blur();if(e.key==='Escape'){inp.removeEventListener('blur',commit);renderInvesting();}});
      };
    }
    wireInline(`pticker-${p.id}`,'ticker','text',v=>v.toUpperCase());
    wireInline(`pbroker-${p.id}`,'broker');
    wireInline(`ptype-${p.id}`,'type');
    wireInline(`pnotes-${p.id}`,'notes');
    wireInline(`pamt-${p.id}`,'monthlyAmount','number');
  });
}

function addPosition(){
  const ticker=(document.getElementById('new-ticker').value||'').trim().toUpperCase();
  const broker=(document.getElementById('new-broker').value||'').trim();
  const type=(document.getElementById('new-type').value||'').trim();
  const amt=parseFloat(document.getElementById('new-inv-amt').value);
  const notes=(document.getElementById('new-inv-notes').value||'').trim();
  if(!ticker||isNaN(amt)||amt<0) return alert('Please enter a ticker and valid amount.');
  positions.push({id:uid(),ticker,broker,type,monthlyAmount:amt,notes});
  svPositions();renderInvesting();renderOverview();
}

function deletePosition(id){
  if(!confirm('Remove this position?')) return;
  positions=positions.filter(p=>p.id!==id);
  svPositions();renderInvesting();renderOverview();
}

// ═══════════════════════════════════════════════════════════════
//  SETTINGS PANEL
// ═══════════════════════════════════════════════════════════════
function renderSettings(){
  const pd=payDates.slice().sort((a,b)=>new Date(a.date)-new Date(b.date));
  document.getElementById('panel-settings').innerHTML=`
  <div class="summary-card">
    <div class="section-label" style="margin-top:0">Budget Name</div>
    <div class="add-row">
      <input class="inp" id="cfg-name" value="${cfg.name}" placeholder="Budget name" />
      <button class="btn" onclick="saveCfgName()">Save</button>
    </div>

    <div class="section-label">Income</div>
    <div class="add-row">
      <div style="flex:1;min-width:120px">
        <div style="font-size:0.63rem;color:var(--muted);margin-bottom:4px">Base Pay ($/mo)</div>
        <input class="inp" type="number" id="cfg-base" value="${cfg.basePay}" min="0" step="1" />
      </div>
      <div style="flex:1;min-width:120px">
        <div style="font-size:0.63rem;color:var(--muted);margin-bottom:4px">Commission ($/mo)</div>
        <input class="inp" type="number" id="cfg-comm" value="${cfg.commission}" min="0" step="1" />
      </div>
      <button class="btn" style="align-self:flex-end" onclick="saveCfgIncome()">Save</button>
    </div>

    <div class="section-label">Play Money Limit</div>
    <div class="add-row">
      <input class="inp" type="number" id="cfg-play" value="${cfg.playLimit}" min="0" step="1" style="max-width:160px" />
      <button class="btn" onclick="saveCfgPlay()">Save</button>
    </div>

    <div class="section-label">Investing Target (%)</div>
    <div class="add-row">
      <input class="inp" type="number" id="cfg-invest" value="${cfg.investTarget}" min="0" max="100" step="1" style="max-width:100px" />
      <button class="btn" onclick="saveCfgInvest()">Save</button>
    </div>
  </div>

  <div class="card">
    <div class="card-header" onclick="toggleCard('pay-dates-body')">
      <span class="card-title">Pay Dates (${pd.length})</span>
      <span style="font-size:0.68rem;color:var(--muted)">▾</span>
    </div>
    <div class="card-body" id="pay-dates-body" style="display:block;padding-top:8px">
      ${pd.length?pd.map((p,i)=>`
        <div class="exp-row">
          <span>${new Date(p.date).toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric',year:'numeric'})}</span>
          <span style="display:flex;align-items:center;gap:8px">
            <span style="font-size:0.68rem;background:var(--surface2);border:1px solid var(--border);padding:1px 6px;border-radius:2px;color:var(--muted)">${p.type}</span>
            <button class="btn sec sm" onclick="deletePayDate(${i})">✕</button>
          </span>
        </div>`).join(''):'<div class="empty-note">No pay dates added yet.</div>'}
      <div class="section-label">Add Pay Date</div>
      <div class="add-row">
        <input class="inp" type="date" id="new-pay-date" />
        <select class="inp" id="new-pay-type" style="max-width:140px">
          <option value="base">Base Pay</option>
          <option value="commission">Commission</option>
        </select>
        <button class="btn" onclick="addPayDate()">+ Add</button>
      </div>
    </div>
  </div>

  <div style="margin-top:16px;display:flex;gap:10px;flex-wrap:wrap">
    <button class="btn ghost-red" onclick="nukeAll()">🗑 Clear All Data</button>
    <span style="font-size:0.67rem;color:var(--muted);align-self:center">Removes everything permanently</span>
  </div>`;
}

function saveCfgName(){cfg.name=(document.getElementById('cfg-name').value||'').trim()||cfg.name;svCfg();renderHeader();}
function saveCfgIncome(){
  const b=parseFloat(document.getElementById('cfg-base').value);
  const c=parseFloat(document.getElementById('cfg-comm').value);
  if(!isNaN(b)&&b>=0)cfg.basePay=b;
  if(!isNaN(c)&&c>=0)cfg.commission=c;
  svCfg();renderHeader();renderOverview();renderInvesting();renderPlay();
}
function saveCfgPlay(){const v=parseFloat(document.getElementById('cfg-play').value);if(!isNaN(v)&&v>=0){cfg.playLimit=v;svCfg();}renderPlay();renderOverview();}
function saveCfgInvest(){const v=parseFloat(document.getElementById('cfg-invest').value);if(!isNaN(v)&&v>=0&&v<=100){cfg.investTarget=v;svCfg();}renderInvesting();renderOverview();}

function addPayDate(){
  const date=document.getElementById('new-pay-date').value;
  const type=document.getElementById('new-pay-type').value;
  if(!date) return alert('Please select a date.');
  if(payDates.find(p=>p.date===date&&p.type===type)) return alert('That date & type already exists.');
  payDates.push({date,type});
  svPayDates();renderSettings();renderHeader();
}
function deletePayDate(idx){payDates.splice(idx,1);svPayDates();renderSettings();renderHeader();}

function nukeAll(){
  if(!confirm('This will delete ALL your data permanently. Are you sure?')) return;
  if(!confirm('Really? This cannot be undone.')) return;
  localStorage.clear();
  location.reload();
}

// ═══════════════════════════════════════════════════════════════
//  UTILS
// ═══════════════════════════════════════════════════════════════
function toggleCard(id){
  const el=document.getElementById(id);
  if(!el)return;
  el.style.display=el.style.display==='none'?'block':'none';
}

function switchTab(tab,btn){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('panel-'+tab).classList.add('active');
}

function resetMonth(){
  if(!confirm('Reset bills & spending for this month?\n(Savings balances and positions are kept.)')) return;
  billsPaid={};playLog=[];savDeposits={};
  svBillsPaid();svPlayLog();svSavDeposits();
  renderAll();
}

document.addEventListener('keydown',e=>{
  if(e.key!=='Enter')return;
  const f=document.activeElement;
  if(!f||!f.id)return;
  if(f.id==='play-amt')addPlay();
  else if(f.id==='new-bill-amt')addBill();
  else if(f.id.startsWith('dep-amt-'))addDeposit(f.id.replace('dep-amt-',''));
  else if(f.id==='new-inv-amt')addPosition();
});

function renderAll(){
  renderHeader();
  renderOverview();
  renderBills();
  renderPlay();
  renderSavings();
  renderInvesting();
  renderSettings();
}

renderAll();
</script>

</body>
</html>
