      ${diff===0?'Exactly on target':diff>0?`${fmt(diff)} over target`:diff<0?`${fmt(Math.abs(diff))} under target`:''}
    </div>
  </div>

  <div class="card">
    <div class="card-header" onclick="toggleCard('inv-body')">
